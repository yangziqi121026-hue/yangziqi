# ============================================================
# 方案一：零代码小白版（推荐用 DeepSeek）
# 只需两步：① 填下面的 DEEPSEEK_API_KEY  ② 把 MOCK_MODE 改成 false
# 系统会自动把接口指向 https://api.deepseek.com、模型用 deepseek-chat
# ============================================================
DEEPSEEK_API_KEY=
MOCK_MODE=true

# ============================================================
# 方案二：专业自定义版（用任意 OpenAI 兼容服务时才填这组）
# 填了 OPENAI_API_KEY 会优先于 DEEPSEEK_API_KEY。
# 想用 DeepSeek 的 reasoner 模型，可把 MODEL_NAME 改成 deepseek-reasoner。
# ============================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
